rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /partidos_en_vivo/{document} {
      allow read: if true;
      allow write: if request.auth != null 
                    && request.auth.token.email == 'administrador@pasionroja.cl';
    }
    match /noticias/{document} {
      allow read: if true;
      allow write: if request.auth != null 
                    && request.auth.token.email == 'administrador@pasionroja.cl';
    }
    match /config_transmision/{document} {
      allow read: if true;
      allow write: if request.auth != null 
                    && request.auth.token.email == 'administrador@pasionroja.cl';
    }
    match /admin_logs/{document} {
      allow read: if request.auth != null 
                    && request.auth.token.email == 'administrador@pasionroja.cl';
      allow write: if request.auth != null 
                    && request.auth.token.email == 'administrador@pasionroja.cl';
    }
    match /{document=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
